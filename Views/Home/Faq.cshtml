@{
    ViewData["Title"] = "FAQ";
}

<div class="hero">
    <h1 class="hero-title">Frequently Asked Questions</h1>
    <p class="hero-desc">Got questions about the KOSOVAPOS Training Simulator? We have answers.</p>
</div>

<div class="faq-section">
    <div class="faq-item">
        <h3>What is KOSOVAPOS?</h3>
        <p>KOSOVAPOS is an advanced Point of Sale training simulator designed to help cashiers and store managers learn the ropes before touching a real register.</p>
    </div>
    
    <div class="faq-item">
        <h3>Is it really a game?</h3>
        <p>Yes, we gamified the learning process so you can level up your POS skills interactively and compete on the leaderboard.</p>
    </div>

    <div class="faq-item">
        <h3>How much does it cost?</h3>
        <p>Check out our Pricing page for more details. We have different tiers depending on your team's size.</p>
    </div>
    
    <div class="faq-item">
        <h3>Do I need special hardware?</h3>
        <p>No special hardware required! KOSOVAPOS runs perfectly in any modern desktop or mobile browser.</p>
    </div>
</div>
