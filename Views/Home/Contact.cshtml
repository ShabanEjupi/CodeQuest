@{
    ViewData["Title"] = "Contact";
}

<div class="hero">
    <div class="hero-inner" style="max-width: 800px; margin: auto;">
        <h1 class="hero-title">Contact Us</h1>
        <p class="hero-sub" style="margin-bottom: 30px;">Get in touch with KOSOVAPOS</p>

        <div style="background: rgba(0,0,0,0.4); border-radius: 8px; padding: 40px; margin-bottom: 30px; border-left: 5px solid #ff5722;">
            <p class="hero-desc" style="font-size: 1.25em; line-height: 1.8; text-align: left;">
                📍 <strong>Address:</strong> Prishtinë, Kosova<br/>
                ✉️ <strong>Email:</strong> info@kosovapos.com<br/>
                📞 <strong>Phone:</strong> +383 45 601 379
            </p>
        </div>

        <div style="background: rgba(255,255,255,0.05); padding: 30px; border-radius: 8px; text-align: left;">
            <h3 style="margin-bottom: 20px;">Send Us a Message</h3>

            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background: #4caf50; color: white; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
                    @TempData["SuccessMessage"]
                </div>
            }

            <form method="post" action="~/Home/SendContactMessage" style="display: flex; flex-direction: column; gap: 15px;">
                <input type="text" name="Name" placeholder="Your Name" required style="padding: 10px; border-radius: 4px; border: none; font-family: inherit;" />
                <input type="email" name="Email" placeholder="Your Email" required style="padding: 10px; border-radius: 4px; border: none; font-family: inherit;" />
                <textarea name="Message" placeholder="How can we help?" rows="5" required style="padding: 10px; border-radius: 4px; border: none; font-family: inherit;"></textarea>
                <button type="submit" class="btn-primary" style="margin-top: 10px; align-self: flex-start; border: none; cursor: pointer;">Send Message</button>
            </form>
        </div>
    </div>
</div>
