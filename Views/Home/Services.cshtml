@{
    ViewData["Title"] = "Services";
}

<div class="hero">
    <div class="hero-inner" style="max-width: 1200px; margin: auto; text-align: left;">
        <h1 class="hero-title" style="text-align: center;">Our Services</h1>
        <p class="hero-sub" style="text-align: center; margin-bottom: 40px;">Tailored POS Solutions</p>

        <div style="display: flex; flex-wrap: wrap; gap: 40px; margin-bottom: 60px; background: rgba(0,0,0,0.4); border-radius: 8px; padding: 30px;">
            <div style="flex: 1; min-width: 300px;">
                <h3 style="color: #ff5722;">🍕 Pizzeria POS</h3>
                <p>Handle orders, customized toppings, and delivery queues faster than ever. Fully integrated with kitchen display systems to optimize the workflow from prep to plate.</p>
                <img src="~/img/kitchen-page.png" alt="Kitchen Display" style="width:100%; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); margin-top: 15px;" />
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h3 style="color: #4caf50;">🛒 Supermarket POS</h3>
                <p>High transaction throughput, integrated barcode scanning, dynamic promotions, and heavy-duty stock management designed for high-volume retail environments.</p>
                <img src="~/img/barcodes-page.png" alt="Barcodes & Items" style="width:100%; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); margin-top: 15px;" />
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h3 style="color: #2196f3;">👕 Clothing POS</h3>
                <p>Keep track of sizes, colors, multi-location inventory, and seasonal trends seamlessly to maximize customer experience and inventory accuracy.</p>
                <img src="~/img/articles-page.png" alt="Articles & Inventory" style="width:100%; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2); margin-top: 15px;" />
            </div>
        </div>

        <h2 style="text-align: center; margin-bottom: 30px; color: #ffeb3b;">Comprehensive Reporting</h2>
        <div style="display: flex; gap: 40px; align-items: center; justify-content: center; background: rgba(0,0,0,0.4); padding: 30px; border-radius: 8px;">
            <div style="flex: 1; min-width: 300px;">
                <img src="~/img/sales-page.png" alt="Sales Data" style="width: 100%; border-radius: 4px;" />
            </div>
            <div style="flex: 1; min-width: 300px;">
                <h4>Real-Time Analytics</h4>
                <p>Track your business performance globally. Whether monitoring a single store's daily sales or enterprise-wide metrics, KOSOVAPOS provides instant, actionable data.</p>
                <p>Analyze sales trends across specific dates, times, and products to inform your strategic decisions.</p>
            </div>
        </div>
    </div>
</div>
