@{
    ViewData["Title"] = "About Us";
}

<div class="hero">
    <div class="hero-inner" style="max-width: 1200px; margin: auto;">
        <h1 class="hero-title">About Us</h1>
        <p class="hero-sub">The story of KOSOVAPOS</p>
        <p class="hero-desc" style="font-size: 1.25em; line-height: 1.6; max-width: 800px; margin: 0 auto 40px auto; text-align: left;">
            We are dedicated to building the most robust, high-performance, and visually appealing Point of Sales software for businesses worldwide, starting from Kosova. 
            Built on top of modern .NET 8 architecture, highly optimized, and scalable via Supabase and PostgreSQL.
        </p>

        <div style="display: flex; gap: 30px; margin-top: 50px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 300px; background: rgba(0,0,0,0.5); padding: 30px; border-radius: 8px;">
                <h3 style="color: #4caf50;">Our Vision</h3>
                <p>To become the leading software solution for modern retail and gastronomy, simplifying complex workflows so owners can focus on what matters most: their customers.</p>
                <img src="~/img/finances-page.png" style="width: 100%; border-radius: 4px; margin-top: 15px;" />
            </div>
            <div style="flex: 1; min-width: 300px; background: rgba(0,0,0,0.5); padding: 30px; border-radius: 8px;">
                <h3 style="color: #2196f3;">Our Partners</h3>
                <p>We build lasting relationships with business partners, creating ecosystems of reliability, trust, and continuous improvement.</p>
                <img src="~/img/business-partners-page.png" style="width: 100%; border-radius: 4px; margin-top: 15px;" />
            </div>
        </div>
    </div>
</div>
