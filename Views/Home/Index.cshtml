@{
    var isSq = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq";
    ViewData["Title"] = isSq ? "Ballina" : "Home";
}

<div class="hero">
    <div class="hero-inner" style="max-width: 1200px; margin: auto;">
        <h1 class="hero-title">@(isSq ? "Mirësevini në KOSOVAPOS" : "Welcome to KOSOVAPOS")</h1>
        <p class="hero-sub" style="font-size: 1.5em; margin-bottom: 20px;">
            @(isSq ? "Zgjidhja Juaj Gjithëpërfshirëse Për Pika Të Shitjes" : "Your All-In-One Point of Sale Solution")
        </p>
        <p class="hero-desc" style="font-size: 1.2em; line-height: 1.6; margin-bottom: 30px;">
            @(isSq ? "Sistemi i gjeneratës së ardhshme i përshtatur për Pizzeri, Supermarkete dhe Dyqane Veshjesh. Performancë e lartë, e bukur në dizajn dhe e ndërtuar për t'u shkallëzuar globalisht. Përjetoni të ardhmen e menaxhimit të shitjes me pakicë." : "The next generation system tailored for Pizzerias, Supermarkets, and Clothing Stores. High performance, beautifully designed, and built to scale globally. Experience the future of retail management.")
        </p>
        <a asp-controller="Home" asp-action="Services" class="btn-primary" style="margin-bottom: 50px; display: inline-block;">
            @(isSq ? "Eksploro Shërbimet Tona" : "Explore Our Services")
        </a>

        <div>
            <img src="~/img/front-pos-page.png" alt="Front POS Dashboard" class="hero-image" />
        </div>

        <div class="home-section-box" style="margin-top: 3rem;">
            <h2>
                @(isSq ? "Fuqizimi i Bizneseve Moderne" : "Empowering Modern Businesses")
            </h2>
            <p>
                @(isSq ? "KOSOVAPOS thekson operacionet tuaja duke unifikuar të gjitha aspektet e biznesit në një platformë intuitive. Qoftë duke menaxhuar porosi të shpejta për pizzeria apo pagesa masive të supermarketeve, KOSOVAPOS është themeli i besueshëm për suksesin e biznesit tuaj. Integrim i plotë, raporte të thella dhe qasje e vazhdueshme e bëjnë këtë sistem një zgjidhje të padiskutueshme." : "KOSOVAPOS streamlines your operations by unifying all business aspects into an intuitive platform. Whether handling fast-paced pizzeria orders or bulk supermarket checkouts, KOSOVAPOS is the dependable foundation for your business's success. With advanced reporting, inventory management, and intuitive user interfaces, managing a modern retail business has never been easier.")
            </p>
        </div>

        <div class="home-grid">
            <div class="home-section-box">
                <h3 style="color: var(--accent-green);">@(isSq ? "Pse të zgjidhni ne?" : "Why Choose Us?")</h3>
                <ul>
                    <li>✅ @(isSq ? "Dizajn modern dhe i lehtë për t'u përdorur" : "Modern and easy-to-use design")</li>
                    <li>✅ @(isSq ? "Shpejtësi dhe performancë e lartë" : "High speed and performance")</li>
                    <li>✅ @(isSq ? "Mbështetje teknike 24/7" : "24/7 technical support")</li>
                    <li>✅ @(isSq ? "Përshtatje sipas nevojave tuaja" : "Customization to your needs")</li>
                </ul>
            </div>
            <div class="home-section-box">
                 <h3 style="color: var(--accent-blue);">@(isSq ? "Kush e përdor KOSOVAPOS?" : "Who Uses KOSOVAPOS?")</h3>
                 <p style="margin-bottom: 1rem; color: var(--text-muted);">@(isSq ? "Sistemi ynë i besohet nga mbi 500+ biznese anembanë Kosovës dhe rajonit, duke përfshirë:" : "Our system is trusted by over 500+ businesses across Kosova and the region, including:")</p>
                 <ul style="list-style-type: disc; padding-left: 20px;">
                    <li>@(isSq ? "Rrjete Restorantesh & Pizzeri" : "Restaurant Chains & Pizzerias")</li>
                    <li>@(isSq ? "Markete & Supermarkete" : "Markets & Supermarkets")</li>
                    <li>@(isSq ? "Dyqane Rrobash & Butiqe" : "Clothing Stores & Boutiques")</li>
                     <li>@(isSq ? "Sallone Bukurie & Spa" : "Beauty Salons & Spas")</li>
                 </ul>
            </div>
        </div>

        <div style="margin-top: 5rem; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 4rem;">
            <h2 style="font-size: 2.5em; margin-bottom: 2rem;">
                @(isSq ? "Çfarë thonë klientët tanë?" : "What do our clients say?")
            </h2>
            <div style="display: flex; gap: 2rem; flex-wrap: wrap; justify-content: center;">
                <div class="home-section-box" style="flex: 1; min-width: 300px; max-width: 350px;">
                    <p style="font-style: italic; color: #ccc;">"KOSOVAPOS ka revolucionarizuar mënyrën se si menaxhojmë arkën tonë. Është shumë i shpejtë, pa gabime dhe mbështetja nga ana e tyre është e jashtëzakonshme."</p>
                    <p style="margin-top: 1rem; font-weight: bold; color: var(--accent-blue);">- Luan Gashi, Supermarket 'Lida'</p>
                </div>
                <div class="home-section-box" style="flex: 1; min-width: 300px; max-width: 350px;">
                    <p style="font-style: italic; color: #ccc;">"Mbase kemi ndërruar pesë sisteme të ndryshme në restorantin tonë gjatë viteve, por që kur vendosëm këtë as që na bie në mend për tjetër. Punon si sahat!"</p>
                    <p style="margin-top: 1rem; font-weight: bold; color: var(--accent-green);">- Arbër Haxhiu, Pizzeria 'Napoli'</p>
                </div>
                <div class="home-section-box" style="flex: 1; min-width: 300px; max-width: 350px;">
                    <p style="font-style: italic; color: #ccc;">"Analizat vizuale dhe sinkronizimi 'Cloud' na ndihmojnë të shohim se cilat rroba na ecin më tepër dhe t'i porositim prapë. Dizajn fantastik!"</p>
                    <p style="margin-top: 1rem; font-weight: bold; color: var(--accent-purple);">- Valmira Deda, Fashion Store</p>
                </div>
            </div>

            <a asp-controller="Home" asp-action="Contact" class="btn-primary" style="margin-top: 3rem; display: inline-block;">
                @(isSq ? "Bëhu pjesë e tregimit tonë!" : "Become part of our story!")
            </a>
        </div>
    </div>
</div>

