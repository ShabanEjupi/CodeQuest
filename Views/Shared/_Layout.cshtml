<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " · KOSOVAPOS" : "KOSOVAPOS: Training Simulator")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body>
    <!-- Scanline overlay -->
    <div class="scanlines" aria-hidden="true"></div>

    <nav class="site-nav">
        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <img src="~/favicon.ico" alt="KOSOVAPOS Logo" class="brand-icon" style="height:24px;width:auto;vertical-align:middle;margin-right:8px;" /> KOSOVAPOS
        </a>
        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index">@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq" ? "Ballina" : "Home")</a>
            <a asp-controller="Home" asp-action="Services">@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq" ? "Shërbimet" : "Services")</a>
            <a asp-controller="Home" asp-action="About">@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq" ? "Rreth Nesh" : "About Us")</a>
            <a asp-controller="Home" asp-action="Contact">@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq" ? "Kontakt" : "Contact")</a>
            <a asp-controller="Home" asp-action="CodeQuest">CodeQuest</a>
            <a asp-controller="Game" asp-action="Leaderboard">@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq" ? "Liderët" : "Leaderboard")</a>

            <form id="langForm" asp-controller="Home" asp-action="SetLanguage" method="post" style="display:inline-block; margin-left: 15px;">
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                <select name="culture" onchange="document.getElementById('langForm').submit();" style="background:#222; color:#fff; border:1px solid #444; border-radius:4px; padding:2px;">
                    <option value="en" selected="@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name != "sq")">English</option>
                    <option value="sq" selected="@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "sq")">Shqip</option>
                </select>
            </form>
        </div>
    </nav>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div>
            <span>KOSOVAPOS v3.0 Training Simulator</span>
            <span>Master your Point of Sale skills, one chapter at a time.</span>
        </div>
        <div style="margin-top: 15px; font-size: 0.9em; opacity: 0.9; text-align: center; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 10px;">
            <p style="font-size: 1.2em; font-weight: bold; margin-bottom: 5px;">
                <img src="~/favicon.ico" alt="KOSOVAPOS Logo" style="height:20px;width:auto;vertical-align:middle;margin-right:4px;" /> KOSOVAPOS <span style="color: #4caf50;">🛒</span> <span style="color: #2196f3;">👕</span>
            </p>
            <p>Your comprehensive Point of Sale system for Pizzerias, Supermarkets, and Clothing Stores.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
