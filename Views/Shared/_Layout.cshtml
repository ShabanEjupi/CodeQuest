<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " · CodeQuest" : "CodeQuest: The Lost Archive")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Scanline overlay -->
    <div class="scanlines" aria-hidden="true"></div>

    <nav class="site-nav">
        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <span class="brand-icon">◈</span> CodeQuest
        </a>
        <div class="nav-links">
            <a asp-controller="Game" asp-action="Leaderboard">Leaderboard</a>
            <a asp-controller="Home" asp-action="Index">New Game</a>
        </div>
    </nav>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <span>CodeQuest: The Lost Archive</span>
        <span>Learn to code, one chapter at a time.</span>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
